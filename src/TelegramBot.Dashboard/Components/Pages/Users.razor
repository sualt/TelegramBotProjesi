@page "/users"
@rendermode InteractiveServer
@using TelegramBot.Core.Models
@using TelegramBot.Infrastructure.Services
@inject UserService UserService

<PageTitle>Kullanıcılar</PageTitle>

<h1 class="page-title">👥 Kullanıcılar</h1>

<div class="toolbar">
    <input class="search-box" placeholder="🔍 Kullanıcı ara..." @bind="searchText" @bind:event="oninput" />
    <select class="filter-select" @bind="filterBlocked">
        <option value="">Tümü</option>
        <option value="false">Aktif</option>
        <option value="true">Engelli</option>
    </select>
</div>

@if (loading)
{
    <div class="loading">⏳ Yükleniyor...</div>
}
else
{
    <div class="panel">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Kullanıcı</th>
                    <th>Telegram ID</th>
                    <th>Son Aktif</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in FilteredUsers)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="avatar">@GetInitial(user.FirstName)</div>
                                <div>
                                    <div class="user-name">@user.FirstName @user.LastName</div>
                                    <div class="user-username">@(user.Username != null ? "@" + user.Username : "-")</div>
                                </div>
                            </div>
                        </td>
                        <td><code>@user.TelegramId</code></td>
                        <td>@user.LastActive.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (user.IsBlocked)
                            {
                                <span class="status blocked">🚫 Engelli</span>
                            }
                            else
                            {
                                <span class="status active">✅ Aktif</span>
                            }
                        </td>
                        <td>
                            <button class="btn @(user.IsBlocked ? "btn-green" : "btn-red")"
                                    @onclick="() => ToggleBlock(user)">
                                @(user.IsBlocked ? "Engeli Kaldır" : "Engelle")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast">@message</div>
    }
}

@code {
    bool loading = true;
    string searchText = "";
    string filterBlocked = "";
    string message = "";
    List<User> users = new();

    IEnumerable<User> FilteredUsers => users
        .Where(u => string.IsNullOrEmpty(searchText) ||
            (u.FirstName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true ||
             u.Username?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true ||
             u.TelegramId.Contains(searchText)))
        .Where(u => string.IsNullOrEmpty(filterBlocked) ||
            u.IsBlocked.ToString().ToLower() == filterBlocked);

    protected override async Task OnInitializedAsync()
    {
        users = await UserService.GetAllUsersAsync(1, 100);
        loading = false;
    }

    async Task ToggleBlock(User user)
    {
        var newState = !user.IsBlocked;
        await UserService.SetBlockedAsync(user.TelegramId, newState);
        user.IsBlocked = newState;
        message = newState ? $"✅ {user.FirstName} engellendi" : $"✅ {user.FirstName} engeli kaldırıldı";
        StateHasChanged();
        await Task.Delay(3000);
        message = "";
        StateHasChanged();
    }

    string GetInitial(string? name) =>
        string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();
}

<style>
    .page-title { color: #7c6af7; margin-bottom: 24px; font-size: 1.5rem; }
    .loading { color: #a0a0b8; padding: 40px; text-align: center; }

    .toolbar { display: flex; gap: 12px; margin-bottom: 20px; }

    .search-box, .filter-select {
        background: #1a1a2e;
        border: 1px solid #2d2d44;
        color: #e0e0e0;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
    }
    .search-box { flex: 1; }
    .search-box:focus, .filter-select:focus { border-color: #7c6af7; }

    .panel { background: #1a1a2e; border-radius: 12px; padding: 20px; border: 1px solid #2d2d44; }

    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { color: #7c6af7; font-size: 0.8rem; padding: 10px 12px; text-align: left; border-bottom: 1px solid #2d2d44; }
    .data-table td { padding: 12px; border-bottom: 1px solid #1f1f35; font-size: 0.9rem; }

    .user-info { display: flex; align-items: center; gap: 10px; }
    .avatar { width: 36px; height: 36px; background: #7c6af7; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; }
    .user-name { color: #fff; font-weight: 500; }
    .user-username { color: #7c6af7; font-size: 0.8rem; }

    code { background: #2d2d44; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; color: #4fcf8f; }

    .status { padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; }
    .status.active { background: #1a3a2a; color: #4fcf8f; }
    .status.blocked { background: #3a1a1a; color: #f95f5f; }

    .btn { padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer; font-size: 0.85rem; transition: opacity 0.2s; }
    .btn:hover { opacity: 0.8; }
    .btn-red { background: #f95f5f; color: #fff; }
    .btn-green { background: #4fcf8f; color: #000; }

    .toast {
        position: fixed; bottom: 24px; right: 24px;
        background: #7c6af7; color: #fff;
        padding: 12px 20px; border-radius: 8px;
        font-size: 0.9rem; animation: fadeIn 0.3s;
    }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>